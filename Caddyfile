opti.alboregroup.com {
	# tRPC - streaming support (no buffering)
	handle /trpc/* {
		reverse_proxy albore-app-api:3000 {
			flush_interval -1
		}
	}

	# REST API
	handle /api/* {
		reverse_proxy albore-app-api:3000
	}

	# Uploaded files
	handle /uploads/* {
		reverse_proxy albore-app-api:3000
	}

	# Frontend SPA (catch-all)
	handle {
		reverse_proxy albore-app-web:80
	}
}
